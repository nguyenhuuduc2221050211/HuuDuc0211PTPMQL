@model IEnumerable<FirstWebMVC.ViewModels.StudentFacultyVM>

<h2>Danh sách sinh viên</h2>
<a asp-action="Create">Thêm sinh viên</a>
|

<a asp-action="ImportExcel">
    Import Excel
</a>

<table border="1">
<tr>
    <th>Mã SV</th>
    <th>Họ tên</th>
    <th>Khoa</th>
    <th>Thao tác</th>
</tr>

@foreach(var item in Model)
{
<tr>
    <td>@item.StudentCode</td>
    <td>@item.Fullname</td>
    <td>@item.FacultyName</td>

    <td>
        <a asp-action="Edit" 
           asp-route-id="@item.StudentCode">
            Sửa
        </a>

        |

        <a asp-action="Delete"
           asp-route-id="@item.StudentCode">
            Xóa
        </a>
    </td>
</tr>
}

</table>