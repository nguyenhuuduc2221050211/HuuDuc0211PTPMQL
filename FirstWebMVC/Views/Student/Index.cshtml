@model IEnumerable<FirstWebMVC.ViewModels.StudentFacultyVM>

<h2>Danh sách sinh viên</h2>

<table border="1">
<tr>
    <th>Mã SV</th>
    <th>Họ tên</th>
    <th>Khoa</th>
</tr>

@foreach(var item in Model)
{
<tr>
    <td>@item.Studentcode</td>
    <td>@item.Fullname</td>
    <td>@item.FacultyName</td>
</tr>
}

</table>