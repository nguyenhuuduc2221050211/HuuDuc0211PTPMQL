<h2>Nhập danh sách sinh viên từ Excel</h2>

@if (ViewBag.Message != null)
{
    <p>@ViewBag.Message</p>
}

<form asp-action="ImportExcel" 
      method="post" 
      enctype="multipart/form-data">

    <input type="file" name="file" />

    <br />
    <br />

    <button type="submit">
        Upload
    </button>

</form>

<br />

<a asp-action="Index">
    Quay lại danh sách sinh viên
</a>