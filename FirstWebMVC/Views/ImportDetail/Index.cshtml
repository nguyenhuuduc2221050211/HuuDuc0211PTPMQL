@model IEnumerable<FirstWebMVC.Models.ImportDetail>

@{
    ViewData["Title"] = "Index";
}

<h1>Chi Tiết Nhập</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.ImportReceipt)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Device)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Quantity)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.ImportPrice)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.ImportReceipt.ImportReceiptID)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Device.DeviceName)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Quantity)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.ImportPrice)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.ImportDetailID">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.ImportDetailID">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.ImportDetailID">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
