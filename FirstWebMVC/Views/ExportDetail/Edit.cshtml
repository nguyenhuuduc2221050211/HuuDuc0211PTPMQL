@model FirstWebMVC.Models.ExportDetail

@{
    ViewData["Title"] = "Edit";
}

<h1>Edit</h1>

<h4>ExportDetail</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="ExportDetailID" />
            <div class="form-group">
                <label asp-for="ExportReceiptID" class="control-label"></label>
                <select asp-for="ExportReceiptID" class="form-control" asp-items="ViewBag.ExportReceiptID"></select>
                <span asp-validation-for="ExportReceiptID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="DeviceID" class="control-label"></label>
                <select asp-for="DeviceID" class="form-control" asp-items="ViewBag.DeviceID"></select>
                <span asp-validation-for="DeviceID" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Quantity" class="control-label"></label>
                <input asp-for="Quantity" class="form-control" />
                <span asp-validation-for="Quantity" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="ExportPrice" class="control-label"></label>
                <input asp-for="ExportPrice" class="form-control" />
                <span asp-validation-for="ExportPrice" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Save" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
